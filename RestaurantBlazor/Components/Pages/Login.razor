@page "/login"
@rendermode InteractiveServer
@inject AuthApiService AuthApi
@inject AuthSession Session

<PageTitle>Login</PageTitle>

<h1>Login</h1>

@if (Session.IsAuthenticated)
{
    <div class="alert alert-success d-flex justify-content-between align-items-center" role="alert">
        <div>Sesion activa como <strong>@Session.Role</strong>.</div>
        <button class="btn btn-sm btn-outline-success" @onclick="DoLogout">Cerrar sesion</button>
    </div>
}
else
{
    <div class="mb-3">
        <label class="form-label" for="usuario">Usuario</label>
        <input id="usuario" class="form-control" @bind="username" autocomplete="username" />
    </div>

    <div class="mb-3">
        <label class="form-label" for="password">Contrasena</label>
        <input id="password" class="form-control" type="password" @bind="password" autocomplete="current-password" />
    </div>

    <button class="btn btn-primary" @onclick="DoLogin">Ingresar</button>
    <p class="text-muted mt-2 mb-0">Credenciales de prueba: mesero / 1234</p>
}

@if (!string.IsNullOrWhiteSpace(message))
{
    <div class="alert @(lastLoginOk ? "alert-success" : "alert-danger") mt-3" role="alert">
        @message
    </div>
}

@code {
    private string username = string.Empty;
    private string password = string.Empty;
    private string message = string.Empty;
    private bool lastLoginOk;

    private async Task DoLogin()
    {
        var result = await AuthApi.LoginAsync(username, password);
        lastLoginOk = result.Ok;
        message = result.Message;
    }

    private void DoLogout()
    {
        AuthApi.Logout();
        lastLoginOk = true;
        message = "Sesion cerrada.";
        username = string.Empty;
        password = string.Empty;
    }
}
